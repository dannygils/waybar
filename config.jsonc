{
  "layer": "top",
  "position": "top",
  "height": 32,

  "modules-left": ["hyprland/workspaces", "hyprland/window", "hyprland/submap"],
  "modules-center": ["custom/shortcuts", "clock", "custom/firefox", "custom/steam", "custom/plex", "custom/signal", "custom/code", "custom/gnome-text-editor", "custom/warp-terminal"],
  "modules-right": ["pulseaudio", "network", "custom/power", "tray"],

  // Workspaces from Hyprland
  "hyprland/workspaces": {
    "format": "{name}",
    "on-click": "activate",
    "all-outputs": true
  },

  // Active window title
  "hyprland/window": {
    "format": "{}",
    "max-length": 80
  },

  // Current Hyprland submap (keybind mode)
  "hyprland/submap": {
    "format": "ď„ś  {name}",
    "max-length": 20,
    "tooltip": false
  },

  // Center clock (e.g. 2026-01-28 - Wednesday - 21:56)
  "clock": {
    "format": "{:%Y-%m-%d - %A - %H:%M}",
    "tooltip": false
  },

  // Network status with live bandwidth in label
  "network": {
    "interval": 1,
    "format": "{ifname}",
    "format-ethernet": "ď›ż  {ifname} ď€™ {bandwidthDownBytes} ď‚“ {bandwidthUpBytes}",
    "format-wifi": "ď‡«  {essid} ď€™ {bandwidthDownBytes} ď‚“ {bandwidthUpBytes}",
    "format-disconnected": "  offline",
    "max-length": 60,
    "on-click-right": "nmcli networking | grep -q enabled && nmcli networking off || nmcli networking on"
  },

  // App launchers https://www.nerdfonts.com/cheat-sheet 
  "custom/firefox": {
    "format": "ď‰©",
    "tooltip": "Firefox",
    "on-click": "firefox",
    "interval": 0
  },

  "custom/steam": {
    "format": "ď†¶",
    "tooltip": "Steam",
    "on-click": "steam",
    "interval": 0
  },

  "custom/plex": {
    "format": "ó°šş",
    "tooltip": false,
    "on-click": "plex-desktop",
    "interval": 0
  },

  "custom/signal": {
    "format": "ó°µ…",
    "tooltip": "Signal",
    "on-click": "signal-desktop --password-store=\"gnome-libsecret\"",
    "interval": 0
  },

  "custom/code": {
    "format": "îŁš",
    "tooltip": "VSCode",
    "on-click": "code",
    "interval": 0
  },

  "custom/gnome-text-editor": {
    "format": "ď…ś",
    "tooltip": "Text Editor",
    "on-click": "gnome-text-editor",
    "interval": 0
  },

  "custom/warp-terminal": {
    "format": "îŞ…",
    "tooltip": "Warp Terminal",
    "on-click": "warp-terminal",
    "interval": 0
  },

  // Hyprland shortcuts helper
  "custom/shortcuts": {
    "format": "ď„ś",
    "tooltip": true,
    "tooltip-format": "Cheat Sheet:\nSuper+E  Nautilus\nSuper+F  Toggle fullscreen\nSuper+J  Toggle split\nSuper+K  Close window\nSuper+L  Lock (hyprlock)\nSuper+P  Pseudo-tile\nSuper+R  App menu (wofi)\nSuper+S  Toggle scratchpad\nSuper+T  Terminal\nSuper+Space  Launcher (hyprlauncher)\nSuper+Arrows  Move focus\nSuper+1-0  Switch workspace\nSuper+Shift+1-0  Move window to workspace\nSuper+Shift+S  Screenshot (region, hyprshot)",
    "interval": 0
  },

  // Power button: left-click lock, right-click shutdown
  "custom/power": {
    "format": "ď€‘",
    "tooltip": "Left: Lock  Right: Shutdown",
    "on-click": "hyprlock",
    "on-click-right": "systemctl poweroff",
    "interval": 0
  },

  // Audio volume
  "pulseaudio": {
    "format": "ď€¨  {volume}%",
    "format-bluetooth": "ďŠ”  {volume}%",
    "format-muted": "ďš©  muted",
    "scroll-step": 1
  },

  // System tray (for nm-applet, etc.)
  "tray": {
    "icon-size": 16,
    "spacing": 6,
    "ignore-list": ["steam", "steam.desktop", "steamwebhelper"]
  }
}
